{
  "name": "mineforge-desktop",
  "version": "1.0.0",
  "description": "MineForge AI Desktop Host Client",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win",
    "build:mac": "tsc && vite build && electron-builder --mac"
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.mineforge.host",
    "productName": "MineForge Host",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "hardenedRuntime": true
    },
    "win": {
      "target": "nsis"
    },
    "protocols": {
      "name": "MineForge Auth",
      "schemes": [
        "mineforge"
      ]
    }
  }
}
